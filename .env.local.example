# Google Gemini API key — https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Vercel KV (populated automatically when you link KV in the Vercel dashboard)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Internal base URL (used for server-side calls to /api/get-prices)
# In production this is set automatically by Vercel.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
